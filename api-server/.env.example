# ═══════════════════════════════════════════════════════
# AgentOTC API Server — Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/agentotc"

# Middleman Agent URL (for forwarding matched deals)
MIDDLEMAN_URL=http://localhost:8080

# HMAC Bridge Secret (shared with middleman)
BRIDGE_SECRET=your-bridge-secret-here

# CORS (comma-separated origins)
CORS_ORIGINS=https://yourdomain.com,http://localhost:3000

# Solana (for on-chain event listener)
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=Hp6RbB21KrKQEaKvqAZPLHYYVDFKNJaiRtzE1494dpmx

# TxLINE Day 1 Snapshot Ingestion
# Use https://txline-dev.txodds.com for devnet subscriptions and https://txline.txodds.com for mainnet.
TXLINE_NETWORK=devnet
TXLINE_API_BASE_URL=https://txline-dev.txodds.com
TXLINE_API_TOKEN=your-activated-txline-api-token
# Optional: leave unset to auto-create a guest JWT via /auth/guest/start.
# TXLINE_GUEST_JWT=your-guest-jwt
TXLINE_ADMIN_TOKEN=replace-with-strong-random-secret
TXLINE_INGESTION_AUTOSTART=true

# SPORT settlement watcher
# Runs beside the API transaction monitor and settles SPORT Arena matches once a final TxLINE outcome exists.
SPORT_SETTLEMENT_MONITOR_ENABLED=true
SPORT_SETTLEMENT_INTERVAL_MS=120000
SPORT_SETTLEMENT_MONITOR_LIMIT=25
SPORT_SETTLEMENT_LIVE_SYNC_ENABLED=true
