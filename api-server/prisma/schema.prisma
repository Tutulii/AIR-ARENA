generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id                String   @id @default(uuid())
  wallet            String   @unique
  createdAt         DateTime @default(now())

  totalDeals        Int      @default(0)
  successfulDeals   Int      @default(0)
  cancelledDeals    Int      @default(0)
  disputedDeals     Int      @default(0)
  totalVolume       String   @default("0")
  avgSettlementTime Float    @default(0)
  reputationScore   Float    @default(0)

  apiKeyHash        String?  @unique // SHA-256 hash of the API key (raw key shown once at registration)

  webhookUrl        String?  // Optional: URL to receive webhook event POST requests
  webhookSecret     String?  // Optional: HMAC SHA-256 secret for signing payloads
  webhookEvents     String?  // Optional JSON array of enabled webhook event names; null = all events

  encryptionPubKey  String?  // X25519 public key (base58) for E2E encrypted DMs

  offers            Offer[]
}

model AgentEvent {
  id          String    @id @default(uuid())
  wallet      String
  event       String
  ticketId    String?
  dealId      String?
  payload     Json
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?
  ackedAt     DateTime?
  expiresAt   DateTime

  @@index([wallet, ackedAt, createdAt])
  @@index([wallet, event, createdAt])
  @@index([expiresAt])
}

model AgentNotificationChannel {
  id         String   @id @default(uuid())
  wallet     String
  type       String
  enabled    Boolean  @default(true)
  events     String?
  config     Json
  lastSentAt DateTime?
  lastError  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([wallet, enabled])
  @@index([wallet, type])
}

model AgentStrategyTemplate {
  id          String   @id @default(uuid())
  wallet      String
  name        String
  description String?
  enabled     Boolean  @default(true)
  defaults    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([wallet, name])
  @@index([wallet, enabled])
  @@index([wallet, updatedAt])
}

model ArenaFixture {
  id        String   @id @default(uuid())
  fixtureId String  @unique
  sport     String  @default("football")
  homeTeam  String?
  awayTeam  String?
  startsAt  DateTime?
  status    String  @default("unknown")
  raw       Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, startsAt])
}

model ArenaOddsUpdate {
  id                 String   @id @default(uuid())
  fixtureId          String
  market             String
  selection          String
  odds               Float
  impliedProbability Float?
  source             String
  sourceUpdateId     String?
  sourceTimestamp    DateTime
  raw                Json
  createdAt          DateTime @default(now())

  @@index([fixtureId, market, selection, sourceTimestamp])
  @@index([sourceUpdateId])
}

model ArenaScoreUpdate {
  id              String   @id @default(uuid())
  fixtureId       String
  homeScore       Int?
  awayScore       Int?
  status          String   @default("unknown")
  source          String
  sourceUpdateId  String?
  sourceTimestamp DateTime
  raw             Json
  createdAt       DateTime @default(now())

  @@index([fixtureId, sourceTimestamp])
  @@index([sourceUpdateId])
}

model ArenaTimelineEvent {
  id              String   @id @default(uuid())
  fixtureId       String
  eventType       String
  homeTeam        String?
  awayTeam        String?
  marketType      String?
  selection       String?
  oddsValue       Float?
  scoreState      Json?
  txlineTimestamp DateTime
  sourceEndpoint  String
  sourceUpdateId  String?
  dedupeKey       String   @unique
  raw             Json
  createdAt       DateTime @default(now())

  @@index([fixtureId, txlineTimestamp, eventType])
  @@index([sourceEndpoint, txlineTimestamp])
}

model ArenaStrategySignal {
  id              String   @id @default(uuid())
  fixtureId       String
  strategy        String
  signalType      String
  marketType      String?
  selection       String?
  direction       String
  confidence      Float
  oddsBefore      Float?
  oddsAfter       Float?
  oddsChangePct   Float?
  impliedBefore   Float?
  impliedAfter    Float?
  impliedDelta    Float?
  scoreContext    Json?
  tradeIntent     Json
  reason          String
  sourceEventIds  Json
  signalTimestamp DateTime
  dedupeKey       String   @unique
  createdAt       DateTime @default(now())

  @@index([fixtureId, strategy, signalTimestamp])
  @@index([strategy, confidence])
}

model ArenaStrategyOffer {
  id         String   @id @default(uuid())
  signalId   String
  offerId    String
  wallet     String
  fixtureId  String
  params     Json
  dedupeKey  String   @unique
  createdAt  DateTime @default(now())

  @@index([signalId])
  @@index([offerId])
  @@index([wallet, createdAt])
}

model ArenaOutcome {
  id              String   @id @default(uuid())
  fixtureId       String   @unique
  status          String
  homeScore       Int
  awayScore       Int
  winner          String
  source          String
  sourceUpdateId  String?
  sourceTimestamp DateTime
  settledAt       DateTime
  raw             Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([winner])
  @@index([sourceTimestamp])
}

model ArenaMatch {
  id                    String   @id @default(uuid())
  fixtureId             String
  signalId              String?
  strategy              String?
  marketType            String?
  selection             String?
  direction             String?
  makerPositionId       String?
  takerPositionId       String?
  makerSide             String?
  stakeLamports         String?
  makerVaultPda         String?
  takerVaultPda         String?
  matchCommitTx         String?
  signalConfidence      Float?

  makerWallet           String
  takerWallet           String?
  buyerWallet           String?
  sellerWallet          String?

  offerId               String?
  ticketId              String?
  escrowPda             String?
  rollupMode            String   @default("NONE")
  status                String   @default("created")

  buyerDepositLamports  String?
  sellerDepositLamports String?
  buyerDepositTx        String?
  sellerDepositTx       String?
  buyerDepositedAt      DateTime?
  sellerDepositedAt     DateTime?

  outcomeId             String?
  outcomeWinner         String?
  winnerWallet          String?
  settlementAction      String?
  settlementStatus      String?
  releaseTx             String?
  refundTx              String?
  settledAt             DateTime?

  proof                 Json
  lastError             String?
  startedAt             DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([fixtureId, status])
  @@index([signalId])
  @@index([offerId])
  @@index([ticketId])
  @@index([makerWallet, createdAt])
  @@index([takerWallet, createdAt])
  @@index([escrowPda])
  @@index([makerPositionId])
  @@index([takerPositionId])
}

model SportPosition {
  id                String   @id @default(uuid())
  fixtureId         String
  selection         String
  side              String
  stakeLamports     String
  filledLamports    String   @default("0")
  remainingLamports String   @default("0")
  refundedLamports  String   @default("0")
  vaultVersion      String   @default("v2")
  agentWallet       String
  status            String   @default("funding_required")
  vaultPda          String?
  fundingTx         String?
  fundedLamports    String?
  fundedAt          DateTime?
  fundingExpiresAt  DateTime?
  cancelTx          String?
  matchedAt         DateTime?
  matchedPositionId String?
  matchId           String?
  offerId           String?
  ticketId          String?
  expiresAt         DateTime
  clientOrderId     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([agentWallet, clientOrderId])
  @@index([fixtureId, status, stakeLamports, createdAt])
  @@index([fixtureId, selection, side, status, fundedAt])
  @@index([fixtureId, selection, side, status, remainingLamports])
  @@index([agentWallet, status, createdAt])
  @@index([expiresAt, status])
  @@index([matchId])
  @@index([offerId])
  @@index([ticketId])
  @@index([vaultPda])
  @@index([vaultVersion])
  @@index([fundedAt])
}

model SportPositionFill {
  id             String    @id @default(uuid())
  fixtureId      String
  selection      String
  backPositionId String
  layPositionId  String
  backWallet     String
  layWallet      String
  fillLamports   String
  ticketId       String?
  escrowPda      String?
  commitTx       String?
  status         String    @default("committing")
  winnerWallet   String?
  releaseTx      String?
  refundTx       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  settledAt      DateTime?

  @@index([fixtureId, status, createdAt])
  @@index([backPositionId, createdAt])
  @@index([layPositionId, createdAt])
  @@index([ticketId])
  @@index([status, createdAt])
}

model SportPositionFundingEvent {
  id          String   @id @default(uuid())
  positionId  String
  wallet      String
  event       String
  txSignature String?
  lamports    String?
  metadata    Json
  createdAt   DateTime @default(now())

  @@index([positionId, createdAt])
  @@index([wallet, createdAt])
  @@index([event, createdAt])
}

model SportIntent {
  id                String    @id @default(uuid())
  wallet            String
  fixtureId         String
  marketType        String    @default("1X2_PARTICIPANT_RESULT")
  selection         String
  side              String
  stakeLamports     String?
  minStakeLamports  String?
  maxStakeLamports  String?
  status            String    @default("active")
  note              String?
  clientIntentId    String?
  expiresAt         DateTime?
  lastNotifiedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([wallet, clientIntentId])
  @@index([fixtureId, selection, side, status, createdAt])
  @@index([wallet, status, createdAt])
  @@index([expiresAt, status])
}

model SportFundingSession {
  id                 String    @id @default(uuid())
  wallet             String    @unique
  sessionId          String
  encryptedSecretKey String
  iv                 String
  authTag            String
  expiresAt          DateTime
  lastUsedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([wallet, expiresAt])
  @@index([expiresAt])
}

model McpAccessToken {
  id          String    @id @default(uuid())
  tokenHash   String    @unique
  tokenPrefix String
  wallet      String
  scopes      String
  expiresAt   DateTime
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([wallet])
  @@index([expiresAt])
}

model Offer {
  id            String   @id @default(uuid())
  creatorId     String
  creatorSettlementWallet String?
  creatorRewardWallet String?
  creatorFundingWallet String?
  asset         String
  price         Float
  amount        Float
  mode          String   // "buy" | "sell"
  rollupMode    String   @default("ER") // NONE | ER | PER | SPORT
  collateral    Float
  tokenMint     String?  // SPL token mint address (null = native SOL)
  tokenDecimals Int      @default(9) // Token decimal precision (9 for SOL, 6 for USDC/USDT)
  fixtureId     String?  // TxLINE fixture ID for SPORT settlement offers
  marketType    String?  // TxLINE market identifier for SPORT settlement offers
  selection     String?  // TxLINE outcome selection, e.g. part1, draw, part2
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  ticket        Ticket?

  creator Agent @relation(fields: [creatorId], references: [id])

  @@index([fixtureId, rollupMode])
}

model Ticket {
  id        String   @id @default(uuid())
  offerId   String   @unique
  buyer     String
  seller    String
  status    String   @default("negotiating") // "negotiating" | "agreed" | "cancelled"
  rollupMode String  @default("ER")
  createdAt DateTime @default(now())

  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id        String   @id @default(uuid())
  ticketId  String
  sender    String
  content   String
  createdAt DateTime @default(now())

  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model DealReputationProcessing {
  dealId    String   @id
  processed Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── Direct Messages (Agent-to-Agent Private Messaging) ───

model DirectMessage {
  id            String    @id @default(uuid())
  fromWallet    String    // Sender's Solana wallet address
  toWallet      String    // Recipient's Solana wallet address
  ticketId      String?   // Optional link to a deal/ticket for context
  content       String    // Message payload (API key, URL, credentials, etc.)
  contentType   String    @default("text") // "text" | "api_key" | "url" | "file_link" | "credentials" | "file"
  encrypted     Boolean   @default(false) // Whether content is E2E encrypted
  metadata      String?   // JSON string for extra data (e.g. { "label": "OpenAI Key", "expiresAt": "..." })
  readAt        DateTime? // Null = unread, set when recipient reads it
  expiresAt     DateTime? // Optional TTL — auto-expire sensitive credentials
  attachmentId  String?   @unique // Optional file attachment
  createdAt     DateTime  @default(now())

  attachment    Attachment? @relation(fields: [attachmentId], references: [id])

  @@index([toWallet, createdAt(sort: Desc)])      // Fast inbox queries
  @@index([fromWallet, toWallet, createdAt])       // Fast conversation lookup
  @@index([ticketId])                               // Fast deal-linked message lookup
  @@index([toWallet, readAt])                       // Fast unread count queries
}

// ─── File Attachments (Agent-to-Agent File Transfer) ───

model Attachment {
  id            String    @id @default(uuid())
  uploaderWallet String   // Who uploaded this file
  filename      String    // Original filename (e.g. "training_data.csv")
  storedName    String    // UUID-based name on disk (prevents collisions)
  mimeType      String    // MIME type (e.g. "application/json", "text/csv")
  sizeBytes     Int       // File size in bytes
  checksum      String    // SHA-256 hash of file content for integrity verification
  encrypted     Boolean   @default(false) // Whether file content is E2E encrypted
  createdAt     DateTime  @default(now())

  message       DirectMessage?

  @@index([uploaderWallet])
}

// ─── Fee Collection (Platform Revenue Tracking) ───

model FeeCollection {
  id          String   @id @default(uuid())
  ticketId    String   // Link to the deal/ticket
  dealPda     String   // On-chain deal PDA address
  buyerWallet String   // Buyer's wallet address
  sellerWallet String  // Seller's wallet address
  dealAmount  String   // Total deal value in lamports/token units
  feeAmount   String   // Fee collected in lamports/token units
  feeRate     Float    // Fee percentage applied (e.g. 1.0 = 1%)
  token       String   @default("SOL") // "SOL" | USDC mint address | token symbol
  txSignature String?  // Transaction signature of the release_funds call
  collectedAt DateTime @default(now())

  @@index([collectedAt(sort: Desc)])
  @@index([buyerWallet])
  @@index([sellerWallet])
}
